SELECT*
From workspace.default.bright_coffee_shop_sales_analysis

-- checking the date range --
select MIN(transaction_date) as minimum_date
from workspace.default.bright_coffee_shop_sales_analysis;

select MAX(transaction_date) as latest_date
from workspace.default.bright_coffee_shop_sales_analysis;

-- checking different store locations
select distinct store_location
from workspace.default.bright_coffee_shop_sales_analysis;

-- checking products sold  --
select distinct product_category
from workspace.default.bright_coffee_shop_sales_analysis;

-- checking product types sold at our stores ---
select distinct product_types
from workspace.default.bright_coffee_shop_sales_analysis;

-- checking product detail ---
select distinct product_detail
from workspace.default.bright_coffee_shop_sales_analysis;

-- grouping revenue by product category (best/least selling products)--

select SUM(unit_price*transaction_qty) AS total_revenue,
       product_category 
from workspace.default.bright_coffee_shop_sales_analysis
group by product_category;

-- calculating total revenue by store location --
select SUM(unit_price*transaction_qty) as total_revenue_per_store,
       store_id,
       store_location
from workspace.default.bright_coffee_shop_sales_analysis
group by store_id,
         store_location
from workspace.default.bright_coffee_shop_sales_analysis;

-- total revenue per product type --

 select SUM(unit_price*transaction_qty) AS total_revenue,
        product_type
from workspace.default.bright_coffee_shop_sales_analysis
group by product_type
order by total_revenue desc;

